{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "main": "expo-router/entry",
  "scripts": {
    "preinstall": "node -e \"if(!/pnpm/i.test(process.env.npm_config_user_agent||'')){console.error('Use pnpm instead');process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck": "pnpm run typecheck:libs && pnpm run typecheck:app && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "expo-av"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av"
        ]
      }
    }
  },
  "devDependencies": {
    "@types/react": "~19.2.17",
    "expo": "~56.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native/codegen": "0.85.3",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "expo": "~56.0.14",
    "expo-asset": "^56.0.17",
    "expo-av": "~16.0.8",
    "expo-constants": "~56.0.20",
    "expo-file-system": "^56.0.8",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image-picker": "~56.0.19",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-notifications": "^56.0.19",
    "expo-router": "~56.2.13",
    "expo-splash-screen": "~56.0.12",
    "jimp": "^1.6.1",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-worklets": "0.8.3"
  }
}